# Sao chép file này thành .env và điền các giá trị thực

# Database
DATABASE_URL=postgresql://admin:secret@postgres:5432/diabetes_db

# Redis
REDIS_URL=redis://redis:6379/0

# JWT — thay bằng chuỗi ngẫu nhiên dài trong production
JWT_SECRET=change-this-to-a-very-long-random-string-in-production
JWT_EXPIRE_MINUTES=1440

# ML Service URL (dùng bên trong Docker network)
ML_SERVICE_URL=http://ml-service:8002

# Firebase (tùy chọn — bỏ qua nếu không cần push notification)
# FIREBASE_CREDENTIALS=/app/firebase-credentials.json
